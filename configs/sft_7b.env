# =============================================================================
# SFT 7B — Full supervised fine-tuning on debugging trajectories
# =============================================================================
#
# 1,593 LLM-generated trajectories spanning all bug types:
#   - Standard mutations, nonlocal bugs, intent-mismatch, LLM-generated programs
#
# System prompt is pre-rendered with tools via Qwen2.5 apply_chat_template,
# so SFT tokenization matches RL exactly.
#
# Expected result: ~56.3% standard, ~40.0% nonlocal, ~7.9% intent-mismatch
#
# Hardware: 2x A100-SXM4-80GB
#
# Launch:
#   dsl-debug setup sft && dsl-debug train sft

EXP_NAME=sft_7b

# --- Data ---
DATA_DIR=/workspace/dsl_debug_data/sft
TRAIN_FILES=/workspace/dsl_debug_data/sft/train.parquet
VAL_FILES=/workspace/dsl_debug_data/sft/val.parquet

# --- Model ---
MODEL_PATH=/workspace/models/Qwen2.5-7B-Instruct

# --- Training ---
TOTAL_EPOCHS=2
MICRO_BSZ=2
TRAIN_BSZ=16
LR=5e-6
MAX_LENGTH=8192

# --- Checkpointing ---
VAL_FREQ=20
SAVE_FREQ=20
