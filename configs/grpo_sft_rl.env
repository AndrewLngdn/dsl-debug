# =============================================================================
# GRPO SFT->RL — GRPO from best SFT checkpoint
# =============================================================================
#
# Continues GRPO from the best SFT checkpoint (step 100, val loss 0.404).
# "SFT->RL" condition: SFT warmup then RL fine-tuning.
#
# Data: 6,406 examples (same as RL-only)
# Expected result: ~83.6% standard, ~71.5% nonlocal, ~24.3% intent-mismatch
#
# Key: all hyperparams identical to RL-only — only the starting checkpoint differs.
#
# Hardware: 2x A100-SXM4-80GB
#
# Launch:
#   dsl-debug setup sft-rl && dsl-debug train sft-rl

EXP_NAME=grpo_sft_rl

# --- Data (same as RL-only) ---
DATA_DIR=/workspace/dsl_debug_data/rl
TRAIN_FILE=train.parquet

# --- Model (SFT checkpoint step 100) ---
MODEL_PATH=/workspace/models/sft_7b_step100

# --- Training (identical to RL-only) ---
TRAIN_BATCH_SIZE=512
VAL_BATCH_SIZE=16
LEARNING_RATE=1e-5
LR_WARMUP_STEPS=2
LR_SCHEDULER_TYPE=cosine
MIN_LR_RATIO=0.1
TOTAL_EPOCHS=6
TOTAL_TRAINING_STEPS=40
MICRO_BATCH_SIZE=4
LOG_PROB_MICRO_BATCH_SIZE=8
ADV_ESTIMATOR=grpo

# --- PPO/GRPO ---
PPO_MINI_BATCH_SIZE=512
PPO_MAX_TOKEN_LEN=12288

# --- Rollout ---
N_ROLLOUTS=8
MAX_TURNS=8
MULTI_STAGE_WAKE_UP=False
FREE_CACHE_ENGINE=True

# --- Hardware (2x A100-SXM4-80GB) ---
N_GPUS=2
TP_SIZE=2
GPU_MEM_UTIL=0.3
MODEL_DTYPE=bfloat16
FSDP_MODEL_DTYPE=bfloat16
ACTOR_PARAM_OFFLOAD=True
OPTIMIZER_OFFLOAD=True
USE_REMOVE_PADDING=True
FORWARD_PREFETCH=True

# --- Reward ---
OVERLONG_PENALTY=false
DAPO_FILTER=true

# --- KL & Entropy ---
USE_KL_LOSS=False
KL_COEF=0.0
KL_CTRL_TYPE=fixed
ENTROPY_COEFF=0.001
ENTROPY_CHUNKING=False
ENTROPY_CHECKPOINTING=False

# --- Loss ---
LOSS_AGG_MODE=seq-mean-token-mean

# --- Checkpointing ---
# TEST_FREQ=999 disables verl's built-in val during training for speed.
# Evaluate post-hoc: merge each FSDP checkpoint, serve with sglang,
# and run dsl-debug eval on the real benchmark splits. See grpo_rl_only.env.
TEST_FREQ=999
SAVE_FREQ=5
MAX_CKPT_TO_KEEP=99
VAL_BEFORE_TRAIN=False
RESUME_MODE=auto
