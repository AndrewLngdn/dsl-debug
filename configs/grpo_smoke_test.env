# =============================================================================
# GRPO Smoke Test — Tiny batch for quick validation
# =============================================================================
# Verifies the full GRPO pipeline: sglang rollouts → reward → gradient step
# Should complete 2 steps in ~5 minutes on 2xA100.

EXP_NAME=grpo_smoke_test

# --- Data ---
DATA_DIR=/workspace/dsl_debug_data/rl
TRAIN_FILE=train.parquet

# --- Model ---
MODEL_PATH=/workspace/models/Qwen2.5-7B-Instruct

# --- Training (tiny batch for fast iteration) ---
TRAIN_BATCH_SIZE=16
VAL_BATCH_SIZE=4
LEARNING_RATE=1e-5
LR_WARMUP_STEPS=0
TOTAL_EPOCHS=1
TOTAL_TRAINING_STEPS=2
MICRO_BATCH_SIZE=2
LOG_PROB_MICRO_BATCH_SIZE=4
ADV_ESTIMATOR=grpo

# --- PPO/GRPO ---
PPO_MINI_BATCH_SIZE=16
PPO_MAX_TOKEN_LEN=12288

# --- Rollout (small n for speed) ---
N_ROLLOUTS=2
MAX_TURNS=4
MULTI_STAGE_WAKE_UP=False
FREE_CACHE_ENGINE=True

# --- Hardware (2x A100-SXM4-80GB) ---
N_GPUS=2
TP_SIZE=2
GPU_MEM_UTIL=0.3
MODEL_DTYPE=bfloat16
FSDP_MODEL_DTYPE=bfloat16
ACTOR_PARAM_OFFLOAD=True
OPTIMIZER_OFFLOAD=True
USE_REMOVE_PADDING=True
FORWARD_PREFETCH=True

# --- Reward ---
OVERLONG_PENALTY=false
DAPO_FILTER=true

# --- KL & Entropy ---
USE_KL_LOSS=False
KL_COEF=0.0
KL_CTRL_TYPE=fixed
ENTROPY_COEFF=0.001
ENTROPY_CHUNKING=False
ENTROPY_CHECKPOINTING=False

# --- Loss ---
LOSS_AGG_MODE=seq-mean-token-mean

# --- Checkpointing ---
TEST_FREQ=999
SAVE_FREQ=999
MAX_CKPT_TO_KEEP=1
VAL_BEFORE_TRAIN=False
RESUME_MODE=disable
