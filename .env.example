# DSL Debug Environment — Optional credentials
# Copy to .env if needed:
#   cp .env.example .env
#
# No credentials are required for training or evaluation.
# All models and data are public.

# WandB (experiment tracking — optional, logs to console without it)
# WANDB_API_KEY=
# WANDB_PROJECT=dsl-debug

# HuggingFace (only needed to push checkpoints to your own repo)
# HF_TOKEN=
